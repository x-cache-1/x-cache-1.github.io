---
const { t } = Astro.props;
const points = t.principle.principlePoints;
---
<section id="principle" class="principle fade-in">
  <div class="shell">
    <span class="kicker">{t.principle.kicker}</span>
    <h2 class="section-title">{t.principle.title}</h2>
    <p class="lede">{t.principle.lede}</p>

    <div class="principle__axes">
      <article class="axis-card axis-card--bad">
        <div class="axis-card__label">{t.principle.axisStepLabel}</div>
        <h3 class="axis-card__title">↦ same chunk · adjacent step</h3>
        <p>{t.principle.axisStepDesc}</p>
        <svg class="axis-card__diagram" viewBox="0 0 320 110" aria-hidden="true">
          <defs>
            <pattern id="dotted-bad" patternUnits="userSpaceOnUse" width="6" height="6">
              <circle cx="3" cy="3" r="0.6" fill="#ff5f5f" />
            </pattern>
          </defs>
          {[0,1,2,3].map((i) => (
            <g>
              <rect x={20 + i * 70} y="22" width="60" height="66" rx="4"
                    fill="#1c1c1e" stroke="#f5f5f7" stroke-width="1.2" />
              <text x={50 + i * 70} y="14" text-anchor="middle"
                    font-family="JetBrains Mono" font-size="9" fill="#98989d">
                step {i}
              </text>
              <line x1={50 + i * 70} y1="55" x2={50 + i * 70 + (i < 3 ? 70 : 0)}
                    y2="55" stroke="#ff5f5f" stroke-width="1.4" stroke-dasharray="3 3" />
            </g>
          ))}
          <text x="160" y="103" text-anchor="middle"
                font-family="JetBrains Mono" font-size="9" fill="#ff5f5f">
            with S=4, this axis is empty
          </text>
        </svg>
      </article>

      <article class="axis-card axis-card--good">
        <div class="axis-card__label">{t.principle.axisChunkLabel}</div>
        <h3 class="axis-card__title">↧ same step · adjacent chunk</h3>
        <p>{t.principle.axisChunkDesc}</p>
        <svg class="axis-card__diagram" viewBox="0 0 320 110" aria-hidden="true">
          {[0,1,2].map((i) => (
            <g>
              <rect x={20 + i * 100} y="14" width="80" height="22" rx="3"
                    fill="#1c1c1e" stroke="#f5f5f7" stroke-width="1" />
              <rect x={20 + i * 100} y="40" width="80" height="22" rx="3"
                    fill="#00a6e8" stroke="#f5f5f7" stroke-width="1" />
              <rect x={20 + i * 100} y="66" width="80" height="22" rx="3"
                    fill="#1c1c1e" stroke="#f5f5f7" stroke-width="1" />
              <text x={60 + i * 100} y="29" text-anchor="middle"
                    font-family="JetBrains Mono" font-size="8" fill="#98989d">
                chunk n{i ? "+" + i : ""}
              </text>
            </g>
          ))}
          <line x1="60" y1="51" x2="220" y2="51"
                stroke="#5dc5f2" stroke-width="1.4" stroke-dasharray="2 3" />
          <line x1="160" y1="51" x2="320" y2="51"
                stroke="#5dc5f2" stroke-width="1.4" stroke-dasharray="2 3" />
          <text x="160" y="103" text-anchor="middle"
                font-family="JetBrains Mono" font-size="9" fill="#5dc5f2">
            block residual reused across (n) → (n+1) at fixed (t, b)
          </text>
        </svg>
      </article>
    </div>

    <div class="schema fade-in">
      <svg viewBox="0 0 1200 320" aria-hidden="true">
        <!-- chunk n -->
        <g transform="translate(40,30)">
          <text font-family="JetBrains Mono" font-size="11" fill="#f5f5f7">CHUNK n  ·  computed</text>
          <rect x="0" y="14" width="280" height="220" fill="#1c1c1e" stroke="#f5f5f7" />
          {[0,1,2,3].map((s) => (
            <g transform={`translate(0,${20 + s*55})`}>
              <text x="6" y="20" font-family="JetBrains Mono" font-size="9" fill="#98989d">t={s}</text>
              {[0,1,2,3,4,5].map((b) => (
                <rect x={26 + b*42} y="6" width="36" height="40"
                      fill={b === 0 ? "#e5b76a" : (b === 5 ? "#6678e0" : "#00a6e8")}
                      opacity="0.85" stroke="#000" stroke-width="0.7" />
              ))}
              {[0,1,2,3,4,5].map((b) => (
                <text x={44 + b*42} y="32" text-anchor="middle"
                      font-family="JetBrains Mono" font-size="9" fill="#000">f{b}</text>
              ))}
            </g>
          ))}
        </g>

        <!-- arrow -->
        <g transform="translate(330,140)">
          <line x1="0" y1="0" x2="50" y2="0" stroke="#f5f5f7" stroke-width="1.4" />
          <polygon points="50,-5 60,0 50,5" fill="#f5f5f7" />
          <text x="0" y="-12" font-family="JetBrains Mono" font-size="9" fill="#f5f5f7">cache (t, b)</text>
          <text x="0" y="20" font-family="JetBrains Mono" font-size="9" fill="#f5f5f7">residuals r̂</text>
        </g>

        <!-- cache slab -->
        <g transform="translate(420,30)">
          <text font-family="JetBrains Mono" font-size="11" fill="#f5f5f7">RESIDUAL CACHE  ·  per (t, b)</text>
          <rect x="0" y="14" width="200" height="220" fill="#00a6e8" opacity="0.10" stroke="#5dc5f2" />
          {[0,1,2,3].map((s) => (
            <g transform={`translate(0,${20 + s*55})`}>
              {[0,1,2,3].map((b) => (
                <rect x={20 + b*42} y="6" width="36" height="40"
                      fill="#5dc5f2" opacity={0.55 - b*0.08}
                      stroke="#00a6e8" stroke-width="0.6" />
              ))}
            </g>
          ))}
          <text x="100" y="252" text-anchor="middle"
                font-family="JetBrains Mono" font-size="9" fill="#5dc5f2">indexed by (t, b)</text>
        </g>

        <!-- arrow -->
        <g transform="translate(630,140)">
          <line x1="0" y1="0" x2="50" y2="0" stroke="#f5f5f7" stroke-width="1.4" />
          <polygon points="50,-5 60,0 50,5" fill="#f5f5f7" />
          <text x="0" y="-12" font-family="JetBrains Mono" font-size="9" fill="#f5f5f7">dual-metric gate</text>
          <text x="0" y="20" font-family="JetBrains Mono" font-size="9" fill="#f5f5f7">cosine ∧ deviation</text>
        </g>

        <!-- chunk n+1 -->
        <g transform="translate(720,30)">
          <text font-family="JetBrains Mono" font-size="11" fill="#f5f5f7">CHUNK n+1  ·  selectively skipped</text>
          <rect x="0" y="14" width="440" height="220" fill="#1c1c1e" stroke="#f5f5f7" />
          {[0,1,2,3].map((s) => (
            <g transform={`translate(0,${20 + s*55})`}>
              <text x="6" y="20" font-family="JetBrains Mono" font-size="9" fill="#98989d">t={s}</text>
              {[0,1,2,3,4,5,6,7,8].map((b) => {
                const isAnchor = b === 0;
                const isTail = b === 8;
                const skip = !isAnchor && !isTail && (b !== 4) && (s !== 0 || b > 1);
                return (
                  <g>
                    <rect x={26 + b*44} y="6" width="38" height="40"
                          fill={skip ? "transparent" : (isAnchor ? "#e5b76a" : (isTail ? "#6678e0" : "#00a6e8"))}
                          stroke={skip ? "#3fb585" : "#000"}
                          stroke-dasharray={skip ? "3 2" : ""}
                          stroke-width="0.8"
                          opacity={skip ? 0.7 : 0.9} />
                    <text x={45 + b*44} y={skip ? 31 : 32} text-anchor="middle"
                          font-family="JetBrains Mono" font-size="9"
                          fill={skip ? "#3fb585" : "#000"}>{skip ? "↺" : `f${b}`}</text>
                  </g>
                );
              })}
            </g>
          ))}
        </g>

        <!-- legend -->
        <g transform="translate(40,275)" font-family="JetBrains Mono" font-size="10" fill="#f5f5f7">
          <rect x="0" y="0" width="14" height="14" fill="#e5b76a" />
          <text x="20" y="11">anchor block (always full)</text>
          <rect x="180" y="0" width="14" height="14" fill="#00a6e8" opacity="0.85" />
          <text x="200" y="11">recompute (gate failed)</text>
          <rect x="360" y="0" width="14" height="14" fill="transparent" stroke="#3fb585" stroke-dasharray="3 2" />
          <text x="380" y="11">skip · reuse cached residual</text>
          <rect x="600" y="0" width="14" height="14" fill="#6678e0" />
          <text x="620" y="11">KV-update protected</text>
        </g>
      </svg>
      <div class="schema__caption">{t.principle.diagramCaption}</div>
    </div>

    <div class="principle__points">
      {points.map((p) => (
        <div class="point fade-in">
          <h3>{p.label}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
