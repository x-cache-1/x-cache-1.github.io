---
const base = import.meta.env.BASE_URL;
const url = (p) => `${base}${String(p).replace(/^\//, "")}`;

/* X-Cache two-mode comparator.
   Three video tracks (baseline, X-Cache, precomputed turbo heatmap) drawn
   into the same stage and kept frame-locked.  The runtime in `Demos.astro`
   surfaces them as:
     • wipe    — drag a seam to reveal one or the other
     • heatmap — swap the cache layer for the turbo-pseudocolour diff
   In addition, the comparator ships a draggable scrubber bar, a click-to-seek
   timeline, and an animated DiT-block ribbon that visualises which of the
   model's 27 blocks are computed vs. reused at each frame. */
const { t, scenario, idx = 0 } = Astro.props;
const id = `cmp-${scenario.id}`;

const skipTag = scenario.tags.find((tag) => /skip/i.test(tag) || /跳过/.test(tag)) ?? "skip 71%";
const speedupTag = scenario.tags.find((tag) => /speedup|加速|×/.test(tag)) ?? "2.6×";

// 27 DiT blocks. A reproducible per-block "skipability" — blocks 1..19 sit
// on the 0.75 plateau, 20..26 fall to ≈ 0.69 (per the paper's plot). Block 0
// is the front anchor, always recomputed. The ribbon below interprets these
// numbers as the per-block probability of being skipped on any given frame.
const NUM_BLOCKS = 27;
const skipProb = Array.from({ length: NUM_BLOCKS }, (_, b) => {
  if (b === 0) return 0;          // anchor
  if (b <= 19) return 0.75;       // plateau
  return 0.69;                    // tail
});
---
<article class="demo__item fade-in">
  <div class="demo__copy">
    <span class="kicker">{scenario.kicker}</span>
    <h3>{scenario.title}</h3>
    <p>{scenario.body}</p>
    <ul class="demo__tags">
      {scenario.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  </div>

  <div class="cmp" data-mode="wipe" id={id}>
    <div class="cmp__stage">
      <div class="cmp__media cmp__media--baseline">
        <video
          data-role="baseline"
          src={url(scenario.baseline)}
          poster={url(scenario.poster)}
          preload="metadata"
          playsinline
          muted
          loop
          aria-label={`${scenario.kicker} · baseline`}>
        </video>
      </div>

      <div class="cmp__media cmp__media--cache cmp__media-clip">
        <video
          data-role="cache"
          src={url(scenario.cache)}
          poster={url(scenario.poster)}
          preload="metadata"
          playsinline
          muted
          loop
          aria-label={`${scenario.kicker} · X-Cache`}>
        </video>
      </div>

      <div class="cmp__media cmp__media--heatmap">
        <video
          data-role="heatmap"
          src={url(scenario.heatmap)}
          preload="metadata"
          playsinline
          muted
          loop
          aria-label={`${scenario.kicker} · diff heatmap`}>
        </video>
      </div>

      <div class="cmp__hud">
        <div class="cmp__hud-pill" data-hud="frame">frame 0 / 264</div>
        <div class="cmp__hud-pill" data-hud="skip">{skipTag}</div>
        <div class="cmp__hud-pill cmp__hud-pill--ember">{speedupTag}</div>
      </div>

      <span class="cmp__label cmp__label--left">{t.demo.labelLeft}</span>
      <span class="cmp__label cmp__label--right">{t.demo.labelRight}</span>

      <div class="cmp__handle" aria-hidden="true">
        <div class="cmp__handle-grip">↔</div>
      </div>

      <!-- DiT block ribbon: 27 blocks visualising recompute vs reuse decisions
           per frame.  Block 0 is the always-on anchor; blocks 1-19 sit on the
           0.75 skip plateau; blocks 20-26 fall to ≈ 0.69. -->
      <div class="cmp__ribbon" aria-hidden="true">
        <div class="cmp__ribbon-label">DiT BLOCKS · 27</div>
        <div class="cmp__ribbon-track">
          {Array.from({ length: NUM_BLOCKS }).map((_, b) => (
            <span class="blk" data-blk={b} data-skip-prob={skipProb[b]}></span>
          ))}
        </div>
      </div>
    </div>

    <!-- Scrubber: timeline + filled bar + chunk markers every 24 frames (every 2 s) -->
    <div class="cmp__scrub" data-role="scrub">
      <div class="cmp__scrub-bar">
        <div class="cmp__scrub-fill" data-role="scrub-fill"></div>
        <div class="cmp__scrub-handle" data-role="scrub-handle"></div>
        <!-- chunk ticks; X-World chunks are 24 frames @ 12fps = 2 seconds -->
        {Array.from({ length: 11 }).map((_, k) => (
          <span class="cmp__scrub-tick" style={`left:${(k / 11) * 100}%`}></span>
        ))}
      </div>
    </div>

    <div class="cmp__controls">
      <div class="cmp__modes" role="group" aria-label="comparison mode">
        <button type="button" class="cmp__mode-btn" data-mode="wipe" aria-pressed="true">{t.demo.modeWipe}</button>
        <button type="button" class="cmp__mode-btn cmp__mode-btn--accent" data-mode="heatmap" aria-pressed="false">{t.demo.modeHeatmap}</button>
      </div>
      <div class="cmp__time">
        <span data-hud="time">0:00 / 0:22</span>
      </div>
      <button type="button" class="cmp__play" data-role="play"
              data-play-label={t.demo.playLabel}
              data-pause-label={t.demo.pauseLabel}>
        <span data-role="play-label">{t.demo.playLabel}</span>
      </button>
    </div>

    <p class="cmp__hint" data-hint>{t.demo.hint}</p>
  </div>
</article>
