---
/* Static-friendly homepage: emit a tiny meta-refresh + JS redirect to /en/.
   We can't use `Astro.redirect()` for `output: 'static'` builds; this works
   in both static and SSR. */
const base = import.meta.env.BASE_URL;
const enUrl = `${base}en/`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>X-Cache</title>
    <meta http-equiv="refresh" content={`0; url=${enUrl}`} />
    <link rel="canonical" href={enUrl} />
    <script is:inline define:vars={{ enUrl }}>
      window.location.replace(enUrl);
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={enUrl}>{enUrl}</a>…</p>
  </body>
</html>
