---
/* Static-friendly homepage: emit a tiny meta-refresh + JS redirect to /en/.
   We can't use `Astro.redirect()` for `output: 'static'` builds; this works
   in both static and SSR. */
const base = import.meta.env.BASE_URL;
const homeUrl = `${base}en/`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>X-Cache</title>
    <meta http-equiv="refresh" content={`0; url=${homeUrl}`} />
    <link rel="canonical" href={homeUrl} />
    <script is:inline define:vars={{ homeUrl }}>
      window.location.replace(homeUrl);
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={homeUrl}>{homeUrl}</a>…</p>
  </body>
</html>
